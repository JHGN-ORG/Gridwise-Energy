# --- Frontend (Vite) ---
# Identifier of the Auth0 API the SPA requests tokens for.
# Must match the "Identifier" field of the Auth0 API you create in the dashboard.
VITE_AUTH0_AUDIENCE=https://griddaddy.us/api

# --- API (Vercel serverless functions) ---
# Auth0 tenant domain (no scheme, no trailing slash).
AUTH0_DOMAIN=dev-obve604xicp5grwj.us.auth0.com
# Same identifier as VITE_AUTH0_AUDIENCE above.
AUTH0_AUDIENCE=https://griddaddy.us/api

# Vercel Postgres (auto-provisioned by the Vercel Postgres integration).
# When you connect a Postgres store in the Vercel dashboard these are populated for you.
POSTGRES_URL=

# --- Backboard AI chatbot (server-side only; never prefix with VITE_) ---
BACKBOARD_API_KEY=
# Optional: create one Backboard assistant in the dashboard/API and reuse it here.
# If omitted, /api/chat can create an assistant on demand for new chat threads.
BACKBOARD_ASSISTANT_ID=
# Optional model routing overrides. Defaults are controlled by Backboard.
BACKBOARD_LLM_PROVIDER=
BACKBOARD_MODEL_NAME=
# Backboard memory mode for messages: Readonly, Auto, or off.
# Keep Readonly/off for a shared BACKBOARD_ASSISTANT_ID; Auto memory is assistant-level.
BACKBOARD_MEMORY_MODE=Readonly
