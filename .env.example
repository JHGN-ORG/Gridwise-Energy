# --- Frontend (Vite) ---
# Identifier of the Auth0 API the SPA requests tokens for.
# Must match the "Identifier" field of the Auth0 API you create in the dashboard.
VITE_AUTH0_AUDIENCE=https://griddaddy.us/api

# --- API (Vercel serverless functions) ---
# Auth0 tenant domain (no scheme, no trailing slash).
AUTH0_DOMAIN=dev-obve604xicp5grwj.us.auth0.com
# Same identifier as VITE_AUTH0_AUDIENCE above.
AUTH0_AUDIENCE=https://griddaddy.us/api

# Vercel Postgres (auto-provisioned by the Vercel Postgres integration).
# When you connect a Postgres store in the Vercel dashboard these are populated for you.
POSTGRES_URL=

# --- Gemini AI chatbot (server-side only; never prefix with VITE_) ---
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TEMPERATURE=0.4
GEMINI_MAX_OUTPUT_TOKENS=800
